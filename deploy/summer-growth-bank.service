[Unit]
Description=Summer Growth Bank API
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
Environment=GROWTH_BANK_DB=/var/lib/summer-growth-bank/growth-bank.sqlite3
Environment=GROWTH_BANK_PORT=8765
WorkingDirectory=/opt/summer-growth-bank
ExecStart=/usr/bin/python3 /opt/summer-growth-bank/server.py
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
